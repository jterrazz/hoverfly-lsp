{
    "data": {
        "pairs": [
            {
                "request": {
                    "path": [{ "matcher": "exact", "value": "/checkout" }],
                    "requiresState": { "cart": "full" }
                },
                "response": {
                    "status": 200,
                    "transitionsState": { "checkout": "started" }
                }
            },
            {
                "request": {
                    "path": [{ "matcher": "exact", "value": "/cart" }],
                    "requiresState": { "checkout": "started" }
                },
                "response": {
                    "status": 200,
                    "transitionsState": { "cart": "full" }
                }
            },
            {
                "request": { "path": [{ "matcher": "exact", "value": "/x" }] },
                "response": {
                    "status": 200,
                    "templated": true,
                    "body": "state={{State.⟦⟧cart}}"
                }
            }
        ]
    },
    "meta": {
        "schemaVersion": "v5.3"
    }
}
