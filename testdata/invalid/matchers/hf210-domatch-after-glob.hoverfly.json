{
    "data": {
        "pairs": [
            {
                "request": {
                    "destination": [
                        {
                            "matcher": "glob",
                            "value": "*.example.com",
                            "doMatch": {
                                "matcher": "regex",
                                "value": "^api\\."
                            }
                        }
                    ]
                },
                "response": {
                    "status": 200
                }
            }
        ]
    },
    "meta": {
        "schemaVersion": "v5.3"
    }
}
