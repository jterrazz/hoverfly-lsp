    "lint:fix": "codestyle fix"
  },
  "devDependencies": {
    "@jterrazz/codestyle": "^3.4.0",
    "@types/node": "^25.5.0",
    "glob": "^13.0.6",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8",
    "vscode-languageserver-protocol": "^3.18.0"
  },
  "engines": {
    "node": ">=20"
  }
