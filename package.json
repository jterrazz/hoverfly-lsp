{
  "name": "hoverfly-lsp-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Language Server for Hoverfly JSON simulation files",
  "license": "MIT",
  "author": "Jean-Baptiste Terrazzoni <contact@jterrazz.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jterrazz/hoverfly-lsp"
  },
  "workspaces": [
